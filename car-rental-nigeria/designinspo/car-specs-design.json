{
  "section": "Car Specifications and Performances",
  "description": "A two-column layout showcasing Tesla Model Y specifications with interior image and detailed specs grid",
  "layout": {
    "type": "two-column",
    "mobile": "stacked",
    "tablet": "stacked",
    "desktop": "side-by-side"
  },
  "leftColumn": {
    "type": "image",
    "content": {
      "image": {
        "src": "/tesla-interior.jpg",
        "alt": "Tesla Model Y interior with steering wheel featuring Tesla logo",
        "aspectRatio": "4:3",
        "style": "black-and-white",
        "focus": "steering-wheel"
      },
      "description": "Close-up black and white photograph of Tesla Model Y interior focusing on the steering wheel with prominent Tesla logo"
    }
  },
  "rightColumn": {
    "type": "content",
    "header": {
      "title": {
        "text": "The Car Specifications and Performances",
        "fontSize": {
          "mobile": "text-2xl",
          "tablet": "text-3xl",
          "desktop": "text-4xl"
        },
        "fontWeight": "font-bold",
        "color": "text-black",
        "marginBottom": "mb-4"
      },
      "subtitle": {
        "text": "Here are the specifications and performances of Tesla Model Y from Battery to every details.",
        "fontSize": {
          "mobile": "text-sm",
          "tablet": "text-base",
          "desktop": "text-lg"
        },
        "fontWeight": "font-normal",
        "color": "text-gray-600",
        "marginBottom": "mb-6"
      }
    },
    "tabs": {
      "type": "toggle-tabs",
      "style": "rounded-rectangle",
      "tabs": [
        {
          "id": "performances",
          "label": "Performances",
          "active": true,
          "style": {
            "background": "bg-black",
            "textColor": "text-white",
            "padding": "px-6 py-3"
          }
        },
        {
          "id": "long-range",
          "label": "Long Range AWD",
          "active": false,
          "style": {
            "background": "bg-white",
            "textColor": "text-black",
            "border": "border border-gray-300",
            "padding": "px-6 py-3"
          }
        }
      ],
      "marginBottom": "mb-8"
    },
    "specifications": {
      "type": "grid",
      "columns": {
        "mobile": 1,
        "tablet": 2,
        "desktop": 2
      },
      "gap": "gap-4",
      "items": [
        {
          "id": "battery",
