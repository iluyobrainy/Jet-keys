          "icon": {
            "type": "person",
            "color": "text-black",
            "size": "w-5 h-5"
          },
          "style": {
            "background": "bg-white",
            "border": "border border-gray-200",
            "padding": "p-4",
            "borderRadius": "rounded-lg"
          }
        },
        {
          "id": "acceleration",
          "category": "ACCELERATION",
          "value": "3.5 s 0-60 mph",
          "icon": {
            "type": "speedometer",
            "color": "text-orange-500",
            "size": "w-5 h-5"
          },
          "style": {
            "background": "bg-white",
            "border": "border border-gray-200",
            "padding": "p-4",
            "borderRadius": "rounded-lg"
          }
