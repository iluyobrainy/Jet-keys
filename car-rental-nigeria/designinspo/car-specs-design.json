            "size": "w-5 h-5"
          },
          "style": {
            "background": "bg-white",
            "border": "border border-gray-200",
            "padding": "p-4",
            "borderRadius": "rounded-lg"
          }
        },
        {
          "id": "top-speed",
          "category": "TOP SPEED",
          "value": "155 mph",
          "icon": {
            "type": "speed",
            "color": "text-black",
            "size": "w-5 h-5"
          },
          "style": {
            "background": "bg-white",
            "border": "border border-gray-200",
