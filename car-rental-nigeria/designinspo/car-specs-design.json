          "value": "Long Range",
          "icon": {
            "type": "battery",
            "color": "text-orange-500",
            "size": "w-5 h-5"
          },
          "style": {
            "background": "bg-white",
            "border": "border border-gray-200",
            "padding": "p-4",
            "borderRadius": "rounded-lg"
          }
        },
        {
          "id": "seating",
