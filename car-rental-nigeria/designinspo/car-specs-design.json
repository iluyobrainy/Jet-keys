  },
  "styling": {
    "container": {
      "background": "bg-white",
      "padding": {
        "mobile": "py-12 px-4",
        "tablet": "py-16 px-6",
        "desktop": "py-24 px-8"
      },
      "maxWidth": "max-w-7xl",
      "margin": "mx-auto"
    },
    "grid": {
      "gap": {
        "mobile": "gap-8",
        "tablet": "gap-12",
        "desktop": "gap-16"
      },
      "alignment": "items-center"
    },
    "typography": {
      "fontFamily": "font-poppins",
      "lineHeight": "leading-tight"
    },
    "colors": {
      "primary": "#000000",
      "secondary": "#6B7280",
      "accent": "#F97316",
      "background": "#FFFFFF",
      "border": "#E5E7EB"
    }
  },
  "responsive": {
    "mobile": {
      "layout": "stacked",
      "imageOrder": "first",
      "contentOrder": "second",
      "textAlignment": "center",
      "specsGrid": "single-column"
    },
    "tablet": {
      "layout": "stacked",
      "imageOrder": "first",
      "contentOrder": "second",
      "textAlignment": "center",
      "specsGrid": "two-columns"
    },
    "desktop": {
      "layout": "side-by-side",
      "imageOrder": "first",
      "contentOrder": "second",
      "textAlignment": "left",
      "specsGrid": "two-columns"
    }
  },
  "accessibility": {
    "ariaLabels": {
      "section": "Car Specifications and Performances",
      "tabs": "Specification categories",
      "specsGrid": "Vehicle specifications grid"
    },
    "focusManagement": "tab-navigation",
    "screenReader": "descriptive-content"
  },
  "seo": {
    "structuredData": {
      "@type": "Product",
      "name": "Tesla Model Y",
      "description": "Tesla Model Y specifications and performance details",
      "brand": "Tesla",
      "model": "Model Y"
    },
    "keywords": "Tesla Model Y, car specifications, electric vehicle, performance, battery range, acceleration"
  }
}
