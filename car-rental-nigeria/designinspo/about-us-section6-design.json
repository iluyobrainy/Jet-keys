{
  "section": "About Us Section 6 - Our Services Carousel",
  "description": "Dynamic service carousel with three cards and updating content based on active slide",
  "layout": {
    "container": "w-full bg-white py-16",
    "content_wrapper": "max-w-7xl mx-auto px-4 sm:px-6 lg:px-8",
    "main_layout": "grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12",
    "text_section": "flex flex-col justify-center",
    "carousel_section": "relative"
  },
  "components": {
    "section_title": {
      "text": "Our Services",
      "font_size": "text-4xl sm:text-5xl lg:text-6xl",
      "font_weight": "font-bold",
      "color": "text-black",
      "alignment": "text-center",
      "margin": "mb-12"
    },
    "dynamic_content": {
      "service_heading": {
        "font_size": "text-3xl sm:text-4xl lg:text-5xl",
        "font_weight": "font-bold",
        "color": "text-black",
        "margin": "mb-4"
      },
      "service_description": {
        "font_size": "text-base sm:text-lg",
        "font_weight": "font-normal",
        "color": "text-black",
        "margin": "mb-6",
        "line_height": "leading-relaxed"
      },
      "learn_more_button": {
        "text": "Learn More",
        "style": "bg-black text-white px-6 py-3 rounded-lg font-medium hover:bg-gray-800 transition-colors"
      }
    },
    "service_cards": [
      {
        "id": 0,
        "title": "Car Rental",
        "description": "Our professional and reliable car rental services provide premium vehicles for all your transportation needs. Choose from our extensive fleet of luxury and economy cars.",
        "image": "/Aboutusui/car-rental-service.jpg",
        "alt": "Car rental service"
      },
      {
        "id": 1,
        "title": "Jet Rental",
        "description": "Experience luxury air travel with our private jet rental services. Professional pilots, premium aircraft, and unmatched comfort for your business and leisure trips.",
        "image": "/Aboutusui/jet-rental-service.jpg",
        "alt": "Jet rental service"
      },
      {
        "id": 2,
        "title": "Security Services",
        "description": "Comprehensive security solutions for your vehicles and properties. Professional security personnel, advanced monitoring systems, and 24/7 protection services.",
        "image": "/Aboutusui/security-service.jpg",
        "alt": "Security service"
      }
    ],
    "carousel": {
      "container": "relative overflow-hidden rounded-lg",
      "card_dimensions": "w-full h-64 sm:h-80",
      "image_style": "object-cover rounded-lg",
      "transition": "transform transition-transform duration-500 ease-in-out"
    },
    "slider_indicators": {
      "container": "flex justify-center space-x-2 mt-6",
      "indicator": "w-8 h-2 rounded-full transition-colors duration-300",
      "active": "bg-black",
      "inactive": "bg-gray-300"
    }
  },
  "functionality": {
    "auto_slide": {
      "enabled": true,
      "interval": "1000ms",
      "pause_on_hover": true
    },
    "manual_navigation": {
      "click_indicators": true,
      "keyboard_support": true
    },
    "dynamic_content": {
      "updates_with_slide": true,
      "smooth_transitions": true
    }
  },
  "styling": {
    "background": "bg-white",
    "padding": "py-16",
    "card_rounded": "rounded-lg",
    "button_hover": "hover:bg-gray-800",
    "transition_duration": "duration-500"
  },
  "responsive": {
    "mobile": {
      "layout": "stacked",
      "card_height": "h-64",
      "title_size": "text-3xl",
      "description_size": "text-base"
    },
    "tablet": {
      "layout": "stacked",
      "card_height": "h-80",
      "title_size": "text-4xl",
      "description_size": "text-lg"
    },
    "desktop": {
      "layout": "two columns",
      "card_height": "h-80",
      "title_size": "text-5xl",
      "description_size": "text-lg"
    }
  }
}
