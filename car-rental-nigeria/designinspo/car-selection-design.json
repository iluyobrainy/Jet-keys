  "pagination": {
    "id": "pagination-section",
    "type": "pagination-controls",
    "layout": {
      "type": "flex",
      "justifyContent": "justify-between",
      "alignItems": "items-center",
      "padding": "pt-6"
    },
    "leftSection": {
      "type": "results-info",
      "content": [
        {
          "type": "text",
          "content": "Showing"
        },
        {
          "type": "dropdown",
          "options": ["5 per page", "10 per page", "20 per page"],
          "defaultValue": "5 per page",
          "styling": {
            "background": "bg-white",
            "border": "border border-gray-300",
            "padding": "px-3 py-1",
            "borderRadius": "rounded-md"
          }
        },
        {
          "type": "text",
          "content": "Total 89 data"
        }
      ]
    },
    "rightSection": {
      "type": "pagination-buttons",
      "buttons": [
        {
          "type": "page-button",
          "number": "1",
          "active": true,
          "styling": {
            "background": "bg-blue-500",
            "textColor": "text-white",
            "padding": "px-3 py-1",
            "borderRadius": "rounded-md"
          }
        },
        {
          "type": "page-button",
          "number": "2",
          "active": false,
          "styling": {
            "background": "bg-gray-200",
            "textColor": "text-gray-700",
            "padding": "px-3 py-1",
            "borderRadius": "rounded-md"
          }
        },
        {
          "type": "page-button",
          "number": "3",
          "active": false,
          "styling": {
            "background": "bg-gray-200",
            "textColor": "text-gray-700",
            "padding": "px-3 py-1",
            "borderRadius": "rounded-md"
          }
        },
        {
          "type": "page-button",
          "number": "4",
          "active": false,
          "styling": {
            "background": "bg-gray-200",
            "textColor": "text-gray-700",
            "padding": "px-3 py-1",
            "borderRadius": "rounded-md"
          }
        },
        {
          "type": "navigation-button",
          "direction": "prev",
          "icon": "chevron-left",
          "styling": {
            "background": "bg-gray-200",
            "textColor": "text-gray-700",
            "padding": "px-3 py-1",
            "borderRadius": "rounded-md"
          }
        },
        {
          "type": "navigation-button",
          "direction": "next",
          "icon": "chevron-right",
          "styling": {
            "background": "bg-gray-200",
            "textColor": "text-gray-700",
            "padding": "px-3 py-1",
            "borderRadius": "rounded-md"
          }
        }
      ]
    }
  },
  "styling": {
    "container": {
      "background": "bg-gray-50",
      "fontFamily": "font-poppins",
      "lineHeight": "leading-normal"
    },
    "card": {
      "background": "bg-white",
      "shadow": "shadow-md",
      "borderRadius": "rounded-lg",
      "padding": "p-4",
      "hover": "hover:shadow-lg",
      "transition": "transition-shadow duration-200"
    },
    "colors": {
      "primaryBackground": "#F9FAFB",
      "cardBackground": "#FFFFFF",
      "primaryText": "#111827",
      "secondaryText": "#6B7280",
      "accentColor": "#3B82F6",
      "ratingColor": "#F59E0B",
      "borderColor": "#E5E7EB"
    },
    "typography": {
      "headings": {
        "fontFamily": "font-poppins",
        "fontWeight": "font-bold"
      },
      "body": {
        "fontFamily": "font-poppins",
        "fontWeight": "font-normal"
      }
    }
  },
  "responsive": {
    "mobile": {
      "popularGrid": "grid-cols-1",
      "othersLayout": "flex-col",
      "pagination": "flex-col gap-4"
    },
    "tablet": {
      "popularGrid": "grid-cols-2",
      "othersLayout": "flex-row",
      "pagination": "flex-row"
    },
    "desktop": {
      "popularGrid": "grid-cols-2",
      "othersLayout": "flex-row",
      "pagination": "flex-row"
    }
  },
  "accessibility": {
    "ariaLabels": {
      "popularSection": "Popular vehicles section",
      "othersSection": "Other vehicles section",
      "pagination": "Pagination controls",
      "vehicleCard": "Vehicle information card"
